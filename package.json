{
  "name": "@bates-solutions/stripe",
  "version": "0.0.0",
  "description": "TypeScript wrapper for the Stripe API with webhook support for Node.js backends",
  "type": "module",
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs": "typedoc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "stripe",
    "stripe-api",
    "payments",
    "payment-processing",
    "typescript",
    "nodejs",
    "backend",
    "webhooks",
    "ecommerce",
    "sdk",
    "api"
  ],
  "author": "Bates Solutions",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mbates/stripe.git"
  },
  "bugs": {
    "url": "https://github.com/mbates/stripe/issues"
  },
  "homepage": "https://github.com/mbates/stripe#readme",
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "stripe": ">=17 <19"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^7.0.0",
    "@semantic-release/git": "^11.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.1.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "stripe": "^22.3.2",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.0.16"
  }
}
